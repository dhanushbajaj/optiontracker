{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "vite",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "functions": {
    "api/scan.ts": { "maxDuration": 30 },
    "api/cron.ts": { "maxDuration": 60 }
  },
  "crons": [
    { "path": "/api/cron", "schedule": "0 13 * * *" },
    { "path": "/api/cron", "schedule": "0 1 * * *" }
  ]
}
